---
const base = import.meta.env.BASE_URL;
const REPO = 'master-of-schedule/master-of-schedule';
const RELEASES_URL = `https://github.com/${REPO}/releases`;

interface GhAsset { name: string; browser_download_url: string; }
interface GhRelease { tag_name: string; assets: GhAsset[]; }

async function fetchLatestReleases(): Promise<{ rshr: GhRelease | null; rn: GhRelease | null }> {
  try {
    const res = await fetch(
      `https://api.github.com/repos/${REPO}/releases?per_page=20`,
      { headers: { Accept: 'application/vnd.github.v3+json' } }
    );
    if (!res.ok) return { rshr: null, rn: null };
    const releases: GhRelease[] = await res.json();
    return {
      rshr: releases.find(r => /^v\d/.test(r.tag_name)) ?? null,
      rn:   releases.find(r => r.tag_name.startsWith('workload/v')) ?? null,
    };
  } catch {
    return { rshr: null, rn: null };
  }
}

function asset(release: GhRelease | null, ext: string): string | null {
  return release?.assets.find(a => a.name.toLowerCase().endsWith(ext))
    ?.browser_download_url ?? null;
}

const { rshr, rn } = await fetchLatestReleases();

const apps = [
  {
    logo: `${base}logos/rshr.png`,
    abbr: 'РШР',
    full: 'Редактор Школьного Расписания',
    color: 'blue',
    version: rshr?.tag_name ?? null,
    macos:   asset(rshr, '.dmg'),
    windows: asset(rshr, '.exe'),
    web:     asset(rshr, '.zip'),
    releasesUrl: RELEASES_URL,
    exampleFile: `${base}example-data.xlsx`,
  },
  {
    logo: `${base}logos/rn.png`,
    abbr: 'РН',
    full: 'Редактор Нагрузки',
    color: 'green',
    version: rn?.tag_name?.replace('workload/', '') ?? null,
    macos:   asset(rn, '.dmg'),
    windows: asset(rn, '.exe'),
    web:     asset(rn, '.zip'),
    releasesUrl: `${RELEASES_URL}?q=workload`,
    exampleFile: null,
  },
];
---

<section class="downloads" id="download">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-eyebrow">Скачать</p>
      <h2 class="section-title">Выберите версию</h2>
      <p class="section-sub">
        Настольное приложение для Windows и macOS или веб-версия — один HTML-файл без установки.
      </p>
    </div>

    <div class="download-grid">
      {apps.map((app, i) => (
        <div class={`download-card download-card-${app.color} reveal reveal-delay-${i + 1}`}>
          <div class="card-top">
            <img src={app.logo} alt={`${app.abbr} логотип`} class="dl-logo" />
            <div class="dl-info">
              <div class={`dl-abbr dl-abbr-${app.color}`}>{app.abbr}</div>
              <div class="dl-full">{app.full}</div>
            </div>
            {app.version && (
              <span class={`version-badge version-badge-${app.color}`}>
                {app.version}
              </span>
            )}
          </div>

          <div class="platform-list">
            <a
              href={app.macos ?? app.releasesUrl}
              class={`platform-btn platform-btn-${app.color}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="platform-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              macOS (.dmg)
            </a>

            <a
              href={app.windows ?? app.releasesUrl}
              class={`platform-btn platform-btn-${app.color}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="platform-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M3 5.557L10.48 4.5v7.008H3V5.557zm0 12.886L10.48 19.5v-6.984H3v5.927zm8.262 1.221L21 21v-8.484h-9.738v7.148zm0-14.328v7.116H21V3l-9.738 1.336z"/>
              </svg>
              Windows (.exe)
            </a>

            <a
              href={app.web ?? app.releasesUrl}
              class={`platform-btn platform-btn-${app.color}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="platform-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <circle cx="12" cy="12" r="9"/>
                <path d="M3.6 9h16.8M3.6 15h16.8M12 3a13.5 13.5 0 0 1 0 18M12 3a13.5 13.5 0 0 0 0 18"/>
              </svg>
              Веб-версия (.zip)
            </a>
          </div>

          <div class="card-footer">
            <a
              href={app.releasesUrl}
              class="all-releases-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              Все версии на GitHub
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            {app.exampleFile && (
              <a href={app.exampleFile} class="example-link" download>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M7 1v8M4 6l3 3 3-3M2 10v1.5A1.5 1.5 0 0 0 3.5 13h7A1.5 1.5 0 0 0 12 11.5V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Пример входных данных (.xlsx)
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .downloads {
    background: var(--bg-subtle);
    padding: 96px 0;
  }

  .section-header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 60px;
  }

  .section-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .section-title {
    font-size: clamp(1.875rem, 3.5vw, 2.625rem);
    font-weight: 800;
    color: var(--text);
    margin-bottom: 14px;
  }

  .section-sub {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .download-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 900px;
    margin: 0 auto;
  }

  .download-card {
    background: white;
    border-radius: var(--radius-xl);
    border: 1.5px solid var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .download-card-blue { border-top: 4px solid var(--blue); }
  .download-card-green { border-top: 4px solid var(--green); }

  .card-top {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 28px 28px 0;
  }

  .dl-logo {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    object-fit: contain;
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
  }

  .dl-info {
    flex: 1;
    min-width: 0;
  }

  .dl-abbr {
    font-family: 'Geologica', sans-serif;
    font-weight: 800;
    font-size: 1.375rem;
    letter-spacing: -0.025em;
  }

  .dl-abbr-blue { color: var(--blue); }
  .dl-abbr-green { color: var(--green); }

  .dl-full {
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-top: 1px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .version-badge {
    font-family: 'Geologica', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 100px;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }

  .version-badge-blue {
    background: var(--blue-50);
    color: var(--blue);
    border: 1px solid var(--blue-100);
  }

  .version-badge-green {
    background: var(--green-50);
    color: var(--green);
    border: 1px solid var(--green-100);
  }

  .platform-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px 28px;
  }

  .platform-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: var(--radius-sm);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-secondary);
    border: 1.5px solid var(--border);
    background: var(--bg-subtle);
    transition: background 0.14s, border-color 0.14s, color 0.14s, transform 0.14s;
    text-decoration: none;
  }

  .platform-btn:hover {
    color: var(--text);
    border-color: var(--border-strong);
    background: white;
    transform: translateX(2px);
  }

  .platform-btn-blue:hover {
    border-color: var(--blue-100);
    background: var(--blue-50);
    color: var(--blue-dark);
  }

  .platform-btn-green:hover {
    border-color: var(--green-100);
    background: var(--green-50);
    color: var(--green-dark);
  }

  .platform-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    opacity: 0.7;
  }

  .card-footer {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px 28px 24px;
    border-top: 1px solid var(--border);
  }

  .all-releases-link,
  .example-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color 0.14s;
  }

  .all-releases-link:hover,
  .example-link:hover {
    color: var(--text-secondary);
  }

  @media (max-width: 680px) {
    .download-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
