<section class="tagline-section">
  <div class="container">
    <p class="tagline-text">
      Наши инструменты не сделают вашу работу за вас,<br />
      но с ними вы сделаете свою работу <span class="tagline-accent">точнее и быстрее</span>.
    </p>
  </div>
</section>

<style>
  .tagline-section {
    padding: 80px 0;
    background: var(--bg-subtle);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .tagline-text {
    font-family: 'Geologica', sans-serif;
    font-size: clamp(1.375rem, 2.8vw, 2rem);
    font-weight: 600;
    color: var(--text);
    line-height: 1.55;
    text-align: center;
    max-width: 680px;
    margin: 0 auto;
  }

  .tagline-accent {
    background: linear-gradient(130deg, var(--blue) 0%, #0d9a6e 50%, var(--green) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
