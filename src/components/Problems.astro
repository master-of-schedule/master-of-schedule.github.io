---
const base = import.meta.env.BASE_URL;

const problems = [
  {
    num: '01',
    role: 'Завуч',
    app: 'РН',
    appColor: 'green',
    logo: `${base}logos/rn.png`,
    given: ['Учебный план', 'Список учителей'],
    find: { label: 'Найти', text: 'Распределение нагрузки' },
    type: 'simple' as const,
    formulaPrefix: 'Вы\u2009+\u2009',
    formulaSuffix: '\u2009=\u2009Нагрузка\u2009+\u2009список\u2009занятий',
  },
  {
    num: '02',
    role: 'Составитель расписания',
    app: 'РШР',
    appColor: 'blue',
    logo: `${base}logos/rshr.png`,
    given: ['Список занятий', 'Список кабинетов', 'Учебная неделя'],
    find: { label: 'Доказать', text: 'Расписание можно составить в срок' },
    type: 'simple' as const,
    formulaPrefix: 'Вы\u2009+\u2009',
    formulaSuffix: '\u2009=\u2009Расписание',
  },
  {
    num: '03',
    role: 'Диспетчер расписания',
    app: 'РШР',
    appColor: 'blue',
    logo: `${base}logos/rshr.png`,
    given: ['Расписание', 'Обстоятельства'],
    find: { label: 'Найти', text: 'Выход' },
    type: 'chain' as const,
    chain: [
      '−\u2009больничные',
      '−\u2009ВПР',
      '−\u2009прорвало\u2009отопление',
      '−\u2009карантин\u2009в\u20094В',
      '−\u2009перенесли\u2009педсовет',
      '−\u2009праздничный\u2009день',
    ],
    conclusion: '=\u2009Расписание',
  },
];

---

<section class="problems">
  <div class="container">
    <div class="problems-grid">
      {problems.map((p) => (
        <div class={`problem-card reveal`}>
          {/* Card header */}
          <div class="card-head">
            <span class="card-num">{p.num}</span>
            <span class="card-role">{p.role}</span>
            <span class={`app-chip app-chip-${p.appColor}`}>
              <img src={p.logo} alt="" class="chip-logo" aria-hidden="true" />
              {p.app}
            </span>
          </div>

          {/* Given */}
          <div class="math-block">
            <span class="math-label">Дано:</span>
            <ul class="given-list">
              {p.given.map(item => <li>{item}</li>)}
            </ul>
          </div>

          {/* Find / Prove */}
          <div class="math-block">
            <span class="math-label">{p.find.label}:</span>
            <span class="math-value">{p.find.text}</span>
          </div>

          {/* Solution */}
          <div class="solution-block">
            <span class="solution-label">Решение</span>

            {p.type === 'simple' && (
              <div class="formula">
                {p.formulaPrefix}
                <span class={`inline-chip inline-chip-${p.appColor}`}>{p.app}</span>
                {p.formulaSuffix}
              </div>
            )}

            {p.type === 'chain' && (
              <>
                <div class="chain-outer">
                  <div class="chain-lines">
                    {p.chain.map(line => (
                      <div class="chain-line">
                        <span class="chain-event">{line}</span>
                        <span class="chain-plus">{'\u2009+\u2009'}</span>
                        <span class="chain-tool">(Вы + РШР)</span>
                      </div>
                    ))}
                  </div>
                  <div class="chain-fade" aria-hidden="true"></div>
                </div>
                <div class="chain-conclusion">
                  <span class="chain-tool">(Вы + РШР)</span>
                  <span class="chain-conclusion-eq">{'\u2009всегда\u2009→\u2009'}</span>
                  <span class="chain-conclusion-result">{p.conclusion}</span>
                </div>
              </>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .problems {
    background: white;
    padding: 80px 0 96px;
  }

  .problems-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: stretch;
  }

  /* ── Card ─── */
  .problem-card {
    position: relative;
    border-radius: var(--radius-xl);
    border: 1.5px solid var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
    display: flex;
    flex-direction: column;

    /* Lined notebook paper */
    background-color: white;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 27px,
      rgba(180, 200, 220, 0.28) 27px,
      rgba(180, 200, 220, 0.28) 28px
    );
  }

  /* Red margin line, like a real notebook */
  .problem-card::before {
    content: '';
    position: absolute;
    left: 36px;
    top: 0;
    bottom: 0;
    width: 1.5px;
    background: rgba(220, 70, 70, 0.15);
    pointer-events: none;
    z-index: 1;
  }

  /* ── Card header ─── */
  .card-head {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 20px 20px 16px 52px;
    border-bottom: 1px solid var(--border);
  }

  .card-num {
    font-family: 'Geologica', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .card-role {
    font-family: 'Geologica', sans-serif;
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--text);
    flex: 1;
    min-width: 0;
  }

  .app-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 8px 3px 4px;
    border-radius: 8px;
    font-family: 'Geologica', sans-serif;
    font-weight: 800;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .app-chip-blue {
    background: var(--blue-50);
    color: var(--blue);
    border: 1px solid var(--blue-100);
  }

  .app-chip-green {
    background: var(--green-50);
    color: var(--green);
    border: 1px solid var(--green-100);
  }

  .chip-logo {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  /* ── Math blocks ─── */
  .math-block {
    display: grid;
    grid-template-columns: 68px 1fr;
    gap: 6px;
    align-items: baseline;
    padding: 10px 20px 0 52px;
  }

  .math-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.01em;
    padding-top: 1px;
  }

  .math-value {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.45;
  }

  .given-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .given-list li {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.45;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .given-list li::before {
    content: '○';
    font-size: 0.6rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  /* ── Solution block ─── */
  .solution-block {
    margin-top: auto;
    border-top: 1px solid var(--border);
    padding: 16px 20px 20px 52px;
    /* Hide stripes in the solution area for cleaner formula display */
    background: rgba(248, 249, 251, 0.85);
  }

  .solution-label {
    display: block;
    font-family: 'Geologica', sans-serif;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 10px;
  }

  .formula {
    font-family: 'Geologica', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
  }

  .inline-chip {
    display: inline-block;
    padding: 1px 7px;
    border-radius: 6px;
    font-weight: 800;
    font-size: 0.9375rem;
  }

  .inline-chip-blue {
    background: var(--blue-50);
    color: var(--blue);
    border: 1px solid var(--blue-100);
  }

  .inline-chip-green {
    background: var(--green-50);
    color: var(--green);
    border: 1px solid var(--green-100);
  }

  /* ── Chain (dispatcher) ─── */
  .chain-outer {
    position: relative;
    max-height: 112px;
    overflow: hidden;
  }

  .chain-lines {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .chain-line {
    font-size: 0.775rem;
    color: var(--text-secondary);
    line-height: 1.5;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: clip;
  }

  .chain-event {
    color: var(--text-secondary);
  }

  .chain-plus {
    color: var(--text-muted);
  }

  .chain-tool {
    color: var(--blue);
    font-weight: 600;
  }

  .chain-conclusion {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px dashed var(--border);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
  }

  .chain-conclusion-eq {
    color: var(--text-muted);
    font-weight: 400;
  }

  .chain-conclusion-result {
    color: var(--text);
    font-weight: 700;
  }

  /* Gradient fade suggesting the list goes on */
  .chain-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 68px;
    background: linear-gradient(to bottom, transparent, rgba(248, 249, 251, 0.97));
    pointer-events: none;
  }

  @media (max-width: 960px) {
    .problems-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .problems-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
