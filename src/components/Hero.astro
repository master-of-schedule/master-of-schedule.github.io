---
const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="hero-fade" aria-hidden="true"></div>

  <div class="container hero-content">
    <div class="hero-badge reveal">
      <span class="badge-dot badge-blue"></span>
      <span class="badge-dot badge-green"></span>
      Инструменты для школы
    </div>

    <h1 class="hero-title reveal reveal-delay-1">
      Расписание и нагрузка —<br />
      <span class="hero-gradient">точно и вовремя</span>
    </h1>

    <p class="hero-sub reveal reveal-delay-2">
      Два приложения для полного цикла: от учебного плана до готового расписания.
      Работают на Windows и macOS, доступны как веб-версия.
    </p>

    <div class="hero-ctas reveal reveal-delay-3">
      <a href="#download" class="hero-btn hero-btn-blue">
        <img src={`${base}logos/rshr.png`} alt="" class="hero-btn-logo" />
        Скачать РШР
      </a>
      <a href="#download" class="hero-btn hero-btn-green">
        <img src={`${base}logos/rn.png`} alt="" class="hero-btn-logo" />
        Скачать РН
      </a>
      <a href="#features" class="hero-btn hero-btn-ghost">
        Подробнее
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 120px 0 100px;
    overflow: hidden;
    background: #fafbfd;
    text-align: center;
    min-height: calc(100vh - var(--nav-h));
    display: flex;
    align-items: center;
  }

  /* Notebook / graph-paper grid */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, #c9d2e0 1px, transparent 1px),
      linear-gradient(to bottom, #c9d2e0 1px, transparent 1px),
      linear-gradient(to right, #dde3ed 1px, transparent 1px),
      linear-gradient(to bottom, #dde3ed 1px, transparent 1px);
    /* major lines every 208px, minor every 52px */
    background-size: 208px 208px, 208px 208px, 52px 52px, 52px 52px;
    opacity: 0.55;
  }

  /* Radial vignette fades the grid at edges and centre */
  .hero-fade {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 85% 70% at 50% 45%, transparent 15%, #fafbfd 72%),
      linear-gradient(to bottom, transparent 55%, var(--bg-subtle) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 100px;
    padding: 7px 18px;
    margin-bottom: 32px;
    box-shadow: var(--shadow-sm);
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .badge-blue  { background: var(--blue); }
  .badge-green { background: var(--green); }

  .hero-title {
    font-size: clamp(2.5rem, 5.5vw, 4.375rem);
    font-weight: 900;
    line-height: 1.08;
    color: var(--text);
    margin-bottom: 24px;
    max-width: 780px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-gradient {
    background: linear-gradient(130deg, var(--blue) 0%, #0d9a6e 50%, var(--green) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.1875rem;
    color: var(--text-secondary);
    max-width: 520px;
    margin: 0 auto 48px;
    line-height: 1.7;
  }

  .hero-ctas {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Outlined download buttons — icon stands out against transparent bg */
  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 13px 26px;
    border-radius: 12px;
    font-family: 'Golos Text', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s, box-shadow 0.15s, transform 0.15s;
  }

  .hero-btn:hover {
    transform: translateY(-2px);
  }

  .hero-btn-blue {
    color: var(--blue);
    border: 2px solid var(--blue);
    background: rgba(26, 86, 219, 0.04);
  }

  .hero-btn-blue:hover {
    background: var(--blue-50);
    box-shadow: 0 6px 22px var(--blue-glow);
  }

  .hero-btn-green {
    color: var(--green);
    border: 2px solid var(--green);
    background: rgba(30, 126, 52, 0.04);
  }

  .hero-btn-green:hover {
    background: var(--green-50);
    box-shadow: 0 6px 22px var(--green-glow);
  }

  .hero-btn-ghost {
    color: var(--text-secondary);
    border: 2px solid var(--border-strong);
    background: transparent;
  }

  .hero-btn-ghost:hover {
    background: var(--bg-subtle);
    color: var(--text);
    border-color: var(--text-muted);
  }

  .hero-btn-logo {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    object-fit: contain;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 80px 0 72px;
      min-height: unset;
    }

    .hero-ctas {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
