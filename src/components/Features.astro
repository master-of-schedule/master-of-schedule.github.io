---
const base = import.meta.env.BASE_URL;

const features = [
  {
    app: 'РШР',
    color: 'blue',
    num: '01',
    title: 'Наглядная сетка расписания',
    body: 'Пять дней, восемь уроков, все классы — в одном редакторе. Цветовая подсветка мгновенно показывает свободные слоты, занятых учителей и перегруженные кабинеты. Никаких таблиц вручную.',
    points: [
      'Сетка 5×8 для каждого класса',
      'Назначение урока — одним кликом',
      'Навигация между классами без перезагрузки',
      'Быстрый поиск по учителю или предмету',
    ],
    image: `${base}screenshots/rshr-editor.png`,
    imageAlt: 'Редактор расписания РШР — сетка',
  },
  {
    app: 'РН',
    color: 'green',
    num: '02',
    title: 'Планирование учебной нагрузки',
    body: 'До того как верстать расписание, нужно распределить часы. РН делает это структурированно: кто, что и сколько часов ведёт. Готовый план выгружается в РШР автоматически.',
    points: [
      'Таблица нагрузки по классам и предметам',
      'Назначение учителей с учётом дублирования',
      'Группировка по кафедрам',
      'Экспорт в формат РШР одним действием',
    ],
    image: `${base}screenshots/rn-assignments.png`,
    imageAlt: 'Редактор нагрузки РН — таблица назначений',
  },
  {
    app: 'РШР',
    color: 'blue',
    num: '03',
    title: 'Умный контроль конфликтов',
    body: 'Попытка поставить учителю два урока одновременно? Кабинет уже занят? РШР предупредит сразу, не даст сохранить ошибку и подсветит конфликт прямо в сетке.',
    points: [
      'Проверка занятости учителей в реальном времени',
      'Контроль загрузки кабинетов',
      'Учёт запретных окон у учителей',
      'Полная история с отменой действий (Ctrl+Z)',
    ],
    image: `${base}screenshots/rshr-conflicts.png`,
    imageAlt: 'РШР — подсветка конфликтов расписания',
  },
  {
    app: 'РН',
    color: 'green',
    num: '04',
    title: 'Структура кафедр',
    body: 'Смотрите нагрузку не только по учителям, но и по кафедрам. Удобно для руководителей: сразу видно, у кого недобор, у кого перегруз, как распределить часы справедливо.',
    points: [
      'Группировка учителей по кафедрам',
      'Сводная нагрузка по отделению',
      'Гибкая настройка состава кафедр',
    ],
    image: `${base}screenshots/rn-departments.png`,
    imageAlt: 'РН — структура кафедр',
  },
];
---

<section class="features" id="features">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-line" aria-hidden="true"></span>
      <h2 class="section-title">Что умеют приложения</h2>
    </div>

    {features.map((f, i) => (
      <div class={`feature-block ${i % 2 === 1 ? 'feature-reverse' : ''}`}>
        <div class="feature-visual reveal">
          <div class="screenshot-frame">
            <div class="screenshot-frame-bar" aria-hidden="true">
              <span class="frame-dot frame-dot-red"></span>
              <span class="frame-dot frame-dot-amber"></span>
              <span class="frame-dot frame-dot-green"></span>
            </div>
            <img
              src={f.image}
              loading="lazy"
              onerror="this.parentElement.innerHTML='<div class=\'screenshot-placeholder\'>Скриншот приложения</div>'"
              alt={f.imageAlt}
            />
          </div>
        </div>

        <div class="feature-text reveal reveal-delay-2">
          <div class="feature-app-tag">
            <img
              src={`${base}logos/${f.color === 'blue' ? 'rshr' : 'rn'}.png`}
              alt=""
              class="feature-app-icon"
              aria-hidden="true"
            />
            <span>{f.num} · {f.app}</span>
          </div>
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-body">{f.body}</p>
          <ul class="feature-list">
            {f.points.map((point) => (
              <li class={`feature-list-item feature-item-${f.color}`}>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="8" fill={f.color === 'blue' ? '#eff6ff' : '#f0fdf4'}/>
                  <path d="M5 8l2.5 2.5L11 5.5" stroke={f.color === 'blue' ? '#1a56db' : '#1e7e34'} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {point}
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .features {
    padding: 96px 0;
  }

  .section-header {
    max-width: 560px;
    margin: 0 0 80px;
  }

  .section-title {
    font-size: clamp(1.875rem, 3.5vw, 2.625rem);
    font-weight: 800;
    color: var(--text);
  }

  /* App tag: icon + number · name */
  .feature-app-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .feature-app-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
  }

  .feature-app-tag span {
    font-family: 'Geologica', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  /* Feature blocks */
  .feature-block {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 64px;
    align-items: center;
    margin-bottom: 100px;
  }

  .feature-block:last-child {
    margin-bottom: 0;
  }

  .feature-reverse {
    grid-template-columns: 0.95fr 1.05fr;
  }

  .feature-reverse .feature-visual {
    order: 2;
  }

  .feature-reverse .feature-text {
    order: 1;
  }

  /* Screenshot */
  .feature-visual .screenshot-frame {
    width: 100%;
  }

  /* Text side */
  .feature-title {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 800;
    color: var(--text);
    margin-bottom: 16px;
    margin-top: 0;
  }

  .feature-body {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 28px;
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .feature-list-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .feature-list-item svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  @media (max-width: 900px) {
    .feature-block,
    .feature-reverse {
      grid-template-columns: 1fr;
      gap: 36px;
      margin-bottom: 72px;
    }

    .feature-reverse .feature-visual,
    .feature-reverse .feature-text {
      order: unset;
    }

    .feature-visual {
      order: -1;
    }
  }
</style>
