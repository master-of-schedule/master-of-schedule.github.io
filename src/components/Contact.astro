---
const contacts = [
  {
    icon: 'github',
    label: 'GitHub',
    value: 'master-of-schedule/master-of-schedule',
    href: 'https://github.com/master-of-schedule/master-of-schedule',
    sub: 'Исходный код и задачи',
  },
  {
    icon: 'email',
    label: 'Электронная почта',
    value: 'info@example.com',
    href: 'mailto:info@example.com',
    sub: 'Вопросы и предложения',
  },
  {
    icon: 'telegram',
    label: 'Telegram',
    value: '@example_group',
    href: 'https://t.me/example_group',
    sub: 'Обсуждение и поддержка',
  },
];
---

<section class="contact" id="contact">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-eyebrow">Контакты</p>
      <h2 class="section-title">Связаться с нами</h2>
      <p class="section-sub">Нашли ошибку, есть идея или просто хотите поздороваться — пишите.</p>
    </div>

    <div class="contact-grid">
      {contacts.map((c, i) => (
        <a
          href={c.href}
          class={`contact-card reveal reveal-delay-${i + 1}`}
          target={c.href.startsWith('mailto') ? undefined : '_blank'}
          rel={c.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
        >
          <div class="contact-icon-wrap">
            {c.icon === 'github' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.268 2.75 1.026A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.026 2.747-1.026.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
              </svg>
            )}
            {c.icon === 'email' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m2 7 10 7 10-7"/>
              </svg>
            )}
            {c.icon === 'telegram' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8-1.7 8.01c-.12.55-.46.68-.93.42l-2.58-1.9-1.24 1.2c-.14.14-.26.26-.52.26l.18-2.64 4.72-4.27c.21-.18-.04-.28-.32-.1L7.62 14.5 5.08 13.7c-.55-.17-.56-.55.12-.82l8.95-3.45c.46-.17.86.11.71.82z"/>
              </svg>
            )}
          </div>
          <div class="contact-content">
            <div class="contact-label">{c.label}</div>
            <div class="contact-value">{c.value}</div>
            <div class="contact-sub">{c.sub}</div>
          </div>
          <svg class="contact-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 13L13 3M13 3H7M13 3v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 96px 0;
  }

  .section-header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 56px;
  }

  .section-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .section-title {
    font-size: clamp(1.875rem, 3.5vw, 2.625rem);
    font-weight: 800;
    color: var(--text);
    margin-bottom: 14px;
  }

  .section-sub {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 900px;
    margin: 0 auto;
  }

  .contact-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 28px 24px;
    background: white;
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--border);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.18s, transform 0.18s, border-color 0.18s;
    position: relative;
  }

  .contact-card:hover {
    box-shadow: var(--shadow);
    transform: translateY(-2px);
    border-color: var(--border-strong);
  }

  .contact-icon-wrap {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--bg-subtle);
    border: 1.5px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    flex-shrink: 0;
    transition: background 0.14s, color 0.14s;
  }

  .contact-card:hover .contact-icon-wrap {
    background: var(--blue-50);
    color: var(--blue);
    border-color: var(--blue-100);
  }

  .contact-content {
    flex: 1;
    min-width: 0;
  }

  .contact-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  .contact-value {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 4px;
    word-break: break-all;
  }

  .contact-sub {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .contact-arrow {
    color: var(--text-muted);
    flex-shrink: 0;
    margin-top: 4px;
    opacity: 0;
    transition: opacity 0.14s;
  }

  .contact-card:hover .contact-arrow {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
